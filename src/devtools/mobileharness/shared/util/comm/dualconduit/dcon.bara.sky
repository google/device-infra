    dcon_build_file_replace("//third_party/golang/envoyproxy/go_control_plane/pkg", "@com_github_envoyproxy_go_control_plane//pkg"),
    dcon_build_file_replace(":pkg_go_proto", ":go_default_library", export_only = True),
