# DualConduit specific definitions.
# Spun off from third_party/deviceinfra/copy.bara.sky for ownership purposes.

DCON_BUILD_FILES = [
    "BUILD",
    "**/BUILD",
    "**.bzl",
]

GOOGLE3_DCON_EXCLUDES = [
]

def dcon_build_file_replace(before_target, after_target):
    """
    Replace package targets (such as in dependencies) with a given prefix with a new prefix.

    Args:
      before_target: a prefix build target path to replace, examples:
              "//java/com/google/common/", "//third_party/absl"
      after_target: a prefix path to replace <before> with, examples:
              "@maven//:com_google_guava_guava", "//@com.google.absl"
    Returns:
      A transform that fixes instances of <before> with <after> in java_package
      rules inside protos. This transform is not guaranteed to be reversible.
  """
    return core.transform(
        transformations = [
            core.replace(
                before = "%s" % before_target,
                after = "%s" % after_target,
                paths = glob(DCON_BUILD_FILES),
            ),
        ],
        ignore_noop = True,
    )

dcon_blaze_to_bazel_transforms = [
    dcon_build_file_replace("//third_party/golang/grpc/codes", "@org_golang_google_grpc//codes"),
    dcon_build_file_replace("//third_party/golang/grpc/reflection", "@org_golang_google_grpc//reflection"),
    dcon_build_file_replace("//third_party/golang/grpc/status", "@org_golang_google_grpc//status"),
    dcon_build_file_replace("//third_party/golang/grpc", "@org_golang_google_grpc//:grpc"),
    dcon_build_file_replace("//third_party/golang/github_com/rsocket/rsocket_go/v/v0/payload", "@com_github_rsocket_rsocket_go//payload"),
    dcon_build_file_replace("//third_party/golang/github_com/rsocket/rsocket_go/v/v0/rx/flux", "@com_github_rsocket_rsocket_go//rx/flux"),
    dcon_build_file_replace("//third_party/golang/github_com/rsocket/rsocket_go/v/v0/rx", "@com_github_rsocket_rsocket_go//rx"),
    dcon_build_file_replace("//third_party/golang/github_com/rsocket/rsocket_go/v/v0/core", "@com_github_rsocket_rsocket_go//core"),
    dcon_build_file_replace("//third_party/deviceinfra/src/devtools/mobileharness/shared/util/comm/dualconduit/rxconn", "//src/devtools/mobileharness/shared/util/comm/dualconduit/rxconn"),
    dcon_build_file_replace("//third_party/golang/github_com/rsocket/rsocket_go/v/v0:rsocket", "@com_github_rsocket_rsocket_go//:rsocket-go"),
    dcon_build_file_replace("//third_party/golang/googleuuid:uuid", "@com_github_google_uuid//:uuid"),
    dcon_build_file_replace("//third_party/golang/protobuf/v2/proto", "@org_golang_google_protobuf//proto"),
    dcon_build_file_replace("//third_party/golang/oauth2/google", "@org_golang_x_oauth2//google"),
]

