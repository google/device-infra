    dcon_build_file_replace("//third_party/golang/go_opentelemetry_io/otel/v/v1/attribute", "@io_opentelemetry_go_otel//attribute"),
    dcon_build_file_replace("//third_party/golang/go_opentelemetry_io/otel/v/v1/propagation", "@io_opentelemetry_go_otel//propagation"),
    dcon_build_file_replace("//third_party/golang/go_opentelemetry_io/otel/v/v1/codes", "@io_opentelemetry_go_otel//codes"),
    dcon_build_file_replace("//third_party/golang/go_opentelemetry_io/otel/v/v1:otel", "@io_opentelemetry_go_otel//:otel"),
