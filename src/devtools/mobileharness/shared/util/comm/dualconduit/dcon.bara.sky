    dcon_build_file_replace("@protobuf//:duration_proto_go_proto", "@org_golang_google_protobuf//types/known/durationpb"),
    dcon_build_file_replace("@protobuf//:wrappers_proto_go_proto", "@org_golang_google_protobuf//types/known/wrapperspb"),
    dcon_build_file_replace("//base/go:runfiles", "@rules_go//go/runfiles"),
    dcon_build_file_replace("//tools/build_defs/go:go_library.bzl", "@rules_go//go:def.bzl"),
    dcon_build_file_replace("//tools/build_defs/go:go_test.bzl", "@rules_go//go:def.bzl"),
    dcon_build_file_replace("//third_party/golang/lumberjack", "@in_gopkg_natefinch_lumberjack_v2//:lumberjack_v2"),
