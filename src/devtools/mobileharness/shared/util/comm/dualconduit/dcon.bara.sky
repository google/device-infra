    dcon_build_file_replace("//third_party/golang/go_opentelemetry_io/otel/exporters/otlp/otlptrace/otlptracegrpc/v/v1:otlptracegrpc", "@io_opentelemetry_go_otel_exporters_otlp_otlptrace_otlptracegrpc//:otlptracegrpc"),
]

